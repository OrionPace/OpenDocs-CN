# NVIDIA NIM API key (required). Free endpoint for deepseek-ai/deepseek-v4-flash.
# Get yours at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# DeepSeek official API key (optional). Paid fallback when NIM is rate-limited.
DEEPSEEK_API_KEY=

# OpenRouter API key (optional). Second fallback.
OPENROUTER_API_KEY=

# OpenRouter model (optional). Defaults to deepseek/deepseek-chat when set.
OPENROUTER_MODEL=

# GitHub token (optional). Raises upstream API rate limit from 60/hr to 5000/hr.
GITHUB_TOKEN=
