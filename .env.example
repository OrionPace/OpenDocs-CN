# DeepSeek API key (required). Primary translation provider.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# OpenRouter API key (optional). Used as fallback when DeepSeek fails.
OPENROUTER_API_KEY=

# OpenRouter model (optional). Defaults to deepseek/deepseek-chat when set.
OPENROUTER_MODEL=

# GitHub token (optional). Raises upstream API rate limit from 60/hr to 5000/hr.
GITHUB_TOKEN=
